DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Production hosts provide a single DATABASE_URL; if set it overrides the DB_* vars.
# DATABASE_URL=postgres://user:password@host:5432/dbname
DB_NAME=complianceai
DB_USER=complianceai
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Comma-separated https origins trusted for CSRF in production (e.g. the frontend URL).
CSRF_TRUSTED_ORIGINS=
# Auth — app-issued session JWTs (signed with DJANGO_SECRET_KEY). Optional TTL.
AUTH_TOKEN_TTL_HOURS=168
# Platform back-office bootstrap: comma-separated emails granted cross-tenant
# access before any PlatformAdmin row exists. Prefer the add_platform_admin cmd.
PLATFORM_ADMIN_EMAILS=
# AWS S3 document storage. All four are required to enable storage; leave
# blank to keep it disabled (upload/download endpoints return 503).
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: presigned URL lifetime in seconds (default 900).
AWS_S3_PRESIGN_EXPIRY=
# --- PDPL KSA re-host: in-Kingdom object storage (Google Cloud Storage) ---
# STORAGE_BACKEND=s3 (default) keeps AWS S3 above; =gcs routes to a GCS bucket in
# me-central2 (Dammam). The GCS path is inert until bucket + SA email + key are set.
STORAGE_BACKEND=s3
GCS_BUCKET_NAME=
GCS_LOCATION=me-central2
GCS_SA_EMAIL=
# PEM private key of the signing service account (\n-escaped is accepted).
GCS_SA_PRIVATE_KEY= # gitleaks:allow  (empty placeholder — real key lives in Secret Manager)
GCS_SIGN_EXPIRY=900
# OCR — Azure Document Intelligence (Arabic-capable), fallback for scanned PDFs.
# Endpoint + key are required to enable; blank keeps OCR disabled.
OCR_AZURE_ENDPOINT=
OCR_AZURE_KEY=
OCR_AZURE_REGION=
# Optional overrides (defaults: prebuilt-read / 2024-11-30).
OCR_AZURE_MODEL=
OCR_AZURE_API_VERSION=
# --- PDPL KSA re-host: in-Kingdom OCR (GCP Document AI, me-central2) ---
# OCR_PROVIDER=azure (default) keeps Azure above; =gcp routes scanned-PDF OCR to
# GCP Document AI. Inert until project + processor + access token are all set.
OCR_PROVIDER=azure
OCR_GCP_PROJECT=
OCR_GCP_LOCATION=me-central2
OCR_GCP_PROCESSOR_ID=
# OAuth bearer; in prod comes from the Cloud Run SA (metadata/ADC). Override here for testing.
OCR_GCP_ACCESS_TOKEN=
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
ANTHROPIC_API_KEY=
# Non-secret. Anthropic model used for contract review; override to upgrade
# without a code change. Defaults to claude-sonnet-4-6.
ANTHROPIC_MODEL=
# Voyage AI embeddings for the RAG assistant. Blank = use the credential-free
# placeholder embedder. Set the key to activate Voyage (model defaults voyage-3).
VOYAGE_API_KEY=
VOYAGE_MODEL=
# --- PDPL KSA re-host: in-Kingdom embeddings (Vertex AI, me-central2) ---
# When all of project + location + model + access token are set, Vertex takes
# precedence over Voyage; otherwise the placeholder/Voyage default is unchanged.
VERTEX_PROJECT=
VERTEX_LOCATION=me-central2
VERTEX_EMBED_MODEL=text-embedding-005
# OAuth bearer; in prod comes from the Cloud Run SA (metadata/ADC). Override here for testing.
VERTEX_ACCESS_TOKEN=
# Fernet key for encrypting per-org SMTP passwords at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, dev derives a key from DJANGO_SECRET_KEY (do NOT rely on that in prod).
EMAIL_CONFIG_ENCRYPTION_KEY=
# Days before a due date that a compliance reminder email is sent.
COMPLIANCE_REMINDER_WINDOW_DAYS=7
# Stripe — subscription billing. Without these the billing endpoints return a
# clear "not configured" error instead of charging.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_BILLING_RETURN_URL=http://localhost:3000/billing
# --- Payments: Moyasar (in-Kingdom, SAMA-aligned PSP) — the default provider ---
# BILLING_PROVIDER=moyasar (default) uses Moyasar; =stripe selects Stripe instead.
# Moyasar uses the Invoices API (hosted payment page). Use your SECRET key
# (sk_test_… / sk_live_…) — NOT the publishable key (pk_…), which is only for the
# in-page card form. Get it from Moyasar Dashboard → API Keys. Blank ⇒ checkout 503s.
BILLING_PROVIDER=moyasar
MOYASAR_SECRET_KEY=
# Shared secret you set on the Moyasar dashboard webhook; the webhook body's
# secret_token is compared against it. Blank ⇒ webhook accepted without that check.
MOYASAR_WEBHOOK_SECRET=
# Defaults below are fine for local dev.
MOYASAR_BASE_URL=https://api.moyasar.com/v1
# Optional public callback URL for per-invoice webhooks (else use a dashboard webhook).
MOYASAR_CALLBACK_URL=
# Where the hosted payment page returns the customer (success/cancel).
BILLING_RETURN_URL=http://localhost:3000/billing
