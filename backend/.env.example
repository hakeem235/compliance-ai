DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Production hosts provide a single DATABASE_URL; if set it overrides the DB_* vars.
# DATABASE_URL=postgres://user:password@host:5432/dbname
DB_NAME=complianceai
DB_USER=complianceai
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Comma-separated https origins trusted for CSRF in production (e.g. the frontend URL).
CSRF_TRUSTED_ORIGINS=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER=
# Optional: only set if you mint Clerk JWTs with a custom audience claim.
# When set, tokens with a missing/wrong `aud` are rejected.
CLERK_JWT_AUDIENCE=
# AWS S3 document storage. All four are required to enable storage; leave
# blank to keep it disabled (upload/download endpoints return 503).
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: presigned URL lifetime in seconds (default 900).
AWS_S3_PRESIGN_EXPIRY=
# OCR — Azure Document Intelligence (Arabic-capable), fallback for scanned PDFs.
# Endpoint + key are required to enable; blank keeps OCR disabled.
OCR_AZURE_ENDPOINT=
OCR_AZURE_KEY=
OCR_AZURE_REGION=
# Optional overrides (defaults: prebuilt-read / 2024-11-30).
OCR_AZURE_MODEL=
OCR_AZURE_API_VERSION=
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
ANTHROPIC_API_KEY=
# Non-secret. Anthropic model used for contract review; override to upgrade
# without a code change. Defaults to claude-sonnet-4-6.
ANTHROPIC_MODEL=
# Voyage AI embeddings for the RAG assistant. Blank = use the credential-free
# placeholder embedder. Set the key to activate Voyage (model defaults voyage-3).
VOYAGE_API_KEY=
VOYAGE_MODEL=
# Fernet key for encrypting per-org SMTP passwords at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, dev derives a key from DJANGO_SECRET_KEY (do NOT rely on that in prod).
EMAIL_CONFIG_ENCRYPTION_KEY=
# Days before a due date that a compliance reminder email is sent.
COMPLIANCE_REMINDER_WINDOW_DAYS=7
# Stripe — subscription billing. Without these the billing endpoints return a
# clear "not configured" error instead of charging.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_BILLING_RETURN_URL=http://localhost:3000/billing
